.container {
  padding: 30rpx;
  min-height: 100vh;
  box-sizing: border-box;
  background: #f5f5f5;
}

/* 月份导航 */
.month-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.nav-arrow {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #4A90D9;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.nav-arrow.disabled {
  color: #ccc;
  background: #f5f5f5;
}

.month-title {
  margin: 0 30rpx;
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

/* 汇总卡片 */
.summary-card {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-num {
  font-size: 36rpx;
  color: #4A90D9;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.summary-num.overtime {
  color: #F5A623;
}

.summary-num.leave {
  color: #9B59B6;
}

.summary-num.absent {
  color: #e64340;
}

.summary-label {
  font-size: 24rpx;
  color: #999;
}

/* 日历网格 */
.calendar {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.weekday-row {
  display: flex;
}

.weekday-cell {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #999;
  padding: 16rpx 0;
}

.day-grid {
  display: flex;
  flex-wrap: wrap;
}

.day-cell {
  width: calc(100% / 7);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 0;
  min-height: 100rpx;
  box-sizing: border-box;
}

.day-cell.other-month {
  opacity: 0.3;
}

.day-cell.today .day-num {
  background: #4A90D9;
  color: #fff;
}

.day-num {
  font-size: 28rpx;
  color: #333;
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  border-radius: 50%;
}

.day-indicator {
  font-size: 18rpx;
  margin-top: 2rpx;
  line-height: 1;
}

.day-indicator.holiday {
  color: #27AE60;
}

.day-indicator.rest {
  color: #bbb;
}

.day-indicator.checked {
  color: #4A90D9;
  font-size: 16rpx;
}

.day-indicator.overtime {
  color: #F5A623;
}

.day-indicator.leave {
  color: #9B59B6;
}

.day-indicator.absent {
  color: #e64340;
}
